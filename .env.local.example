# ============================================================
# JULIES ART — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the browser, only use server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Stripe
# ------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Get this from: https://dashboard.stripe.com/webhooks
# For local dev, use Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------
# Resend (email)
# ------------------------------------------------------------
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# The verified sender domain/address configured in Resend
RESEND_FROM_EMAIL=Julies Art <bestellingen@juliesart.nl>
