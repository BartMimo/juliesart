# ============================================================
# JULIES ART — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ------------------------------------------------------------
# SUPABASE
# ------------------------------------------------------------
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# STRIPE
# ------------------------------------------------------------
# Find these in: Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret: created when you register the webhook endpoint
# For local dev, use: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------
# RESEND (email)
# ------------------------------------------------------------
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# The verified sender domain/address you set up in Resend
RESEND_FROM_EMAIL=bestellingen@juliesart.nl

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Used for admin login — set the email of the admin user
NEXT_PUBLIC_ADMIN_EMAIL=admin@juliesart.nl
